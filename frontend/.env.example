# Google AdSense Mode
# Set to "test" for local development (uses simulated ads)
# Set to "real" for production (uses real Google IMA SDK with AdSense)
# Default: test
NEXT_PUBLIC_ADSENSE_MODE=test

# Google AdSense Configuration
# Get your ad unit ID from Google AdSense dashboard:
# 1. Go to https://adsense.google.com
# 2. Sign in or create account
# 3. Navigate to "Ads" → "Ad units"
# 4. Create or select an in-stream video ad unit
# 5. Copy the ad unit ID (format: ca-pub-xxxxxxxxxxxxxxxx)
# For test mode, use Google's test unit: ca-pub-3626050409831541
# For real mode, use your actual AdSense unit ID
NEXT_PUBLIC_ADSENSE_UNIT_ID=ca-pub-xxxxxxxxxxxxxxxx

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
